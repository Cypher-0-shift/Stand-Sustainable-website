'use server';

import { Resend } from 'resend';

// Only attempt to initialize if API key exists to prevent crashing during build
const resend = process.env.RESEND_API_KEY ? new Resend(process.env.RESEND_API_KEY) : null;

export type EmailResponse = {
  success: boolean;
  message: string;
};

export async function sendContactEmail(formData: FormData): Promise<EmailResponse> {
  const name = formData.get('name') as string;
  const email = formData.get('email') as string;
  const subject = formData.get('subject') as string;
  const message = formData.get('message') as string;

  if (!name || !email || !subject || !message) {
    return { success: false, message: 'All fields are required.' };
  }

  if (!resend) {
    console.warn('RESEND_API_KEY is not set. Simulating success.');
    return { success: true, message: 'Simulated success (no API key).' };
  }

  try {
    const data = await resend.emails.send({
      from: 'Stand Sustainable Website <onboarding@resend.dev>', // Use verified domain here in prod
      to: 'sinhatushar06@gmail.com', // Replace with the actual recipient email
      replyTo: email,
      subject: `New Contact Form Submission: ${subject}`,
      html: `
        <h2>New Message from ${name}</h2>
        <p><strong>Email:</strong> ${email}</p>
        <p><strong>Subject:</strong> ${subject}</p>
        <hr />
        <p>${message.replace(/\n/g, '<br>')}</p>
      `,
    });

    if (data.error) {
      console.error('Resend error:', data.error);
      return { success: false, message: data.error.message };
    }

    return { success: true, message: 'Message sent successfully.' };
  } catch (error: any) {
    console.error('Error sending email:', error);
    return { success: false, message: 'An unexpected error occurred.' };
  }
}

export async function sendPartnerEmail(formData: FormData): Promise<EmailResponse> {
  const name = formData.get('name') as string;
  const email = formData.get('email') as string;
  const interest = formData.get('interest') as string;
  const message = formData.get('message') as string;

  if (!name || !email || !interest || !message) {
    return { success: false, message: 'All fields are required.' };
  }

  if (!resend) {
    console.warn('RESEND_API_KEY is not set. Simulating success.');
    return { success: true, message: 'Simulated success (no API key).' };
  }

  try {
    const data = await resend.emails.send({
      from: 'Stand Sustainable Website <onboarding@resend.dev>', // Use verified domain here in prod
      to: 'sinhatushar06@gmail.com', // Replace with the actual recipient email
      replyTo: email,
      subject: `New Partnership Inquiry: ${name}`,
      html: `
        <h2>New Partnership Inquiry from ${name}</h2>
        <p><strong>Email:</strong> ${email}</p>
        <p><strong>Area of Interest:</strong> ${interest}</p>
        <hr />
        <p>${message.replace(/\n/g, '<br>')}</p>
      `,
    });

    if (data.error) {
      console.error('Resend error:', data.error);
      return { success: false, message: data.error.message };
    }

    return { success: true, message: 'Message sent successfully.' };
  } catch (error: any) {
    console.error('Error sending email:', error);
    return { success: false, message: 'An unexpected error occurred.' };
  }
}
